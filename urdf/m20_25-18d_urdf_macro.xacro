<!-- URDF for M-20/25-18D (M-20iD/25) -->
<robot xmlns:xacro="http://wiki.ros.org/xacro">
  <xacro:macro
    name="m20_25-18d"
    params="prefix=''
            parent
            *origin
            child"
  >

    <xacro:property name="j1_lower_limit" value="${radians(-185)}" />
    <xacro:property name="j2_lower_limit" value="${radians(-100)}" />
    <xacro:property name="j3_lower_limit" value="${radians(-90)}" />
    <xacro:property name="j4_lower_limit" value="${radians(-200)}" />
    <xacro:property name="j5_lower_limit" value="${radians(-179.999)}" />
    <xacro:property name="j6_lower_limit" value="${radians(-450)}" />

    <xacro:property name="j1_upper_limit" value="${radians(185)}" />
    <xacro:property name="j2_upper_limit" value="${radians(160)}" />
    <xacro:property name="j3_upper_limit" value="${radians(220)}" />
    <xacro:property name="j4_upper_limit" value="${radians(200)}" />
    <xacro:property name="j5_upper_limit" value="${radians(179.999)}" />
    <xacro:property name="j6_upper_limit" value="${radians(450)}" />

    <xacro:property name="j1_effort_limit" value="7000" />
    <xacro:property name="j2_effort_limit" value="8000" />
    <xacro:property name="j3_effort_limit" value="4000" />
    <xacro:property name="j4_effort_limit" value="300" />
    <xacro:property name="j5_effort_limit" value="300" />
    <xacro:property name="j6_effort_limit" value="200" />

    <xacro:property name="j1_velocity_limit" value="${radians(210)}" />
    <xacro:property name="j2_velocity_limit" value="${radians(210)}" />
    <xacro:property name="j3_velocity_limit" value="${radians(265)}" />
    <xacro:property name="j4_velocity_limit" value="${radians(420)}" />
    <xacro:property name="j5_velocity_limit" value="${radians(420)}" />
    <xacro:property name="j6_velocity_limit" value="${radians(720)}" />

    <!-- links -->
    <link name="${prefix}base_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://robot_description/meshes/visual/base.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://robot_description/meshes/collision/base.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 45.8" />
        <origin xyz="-.0767  .00288  .109" />
        <inertia
          ixx=" .497"
          ixy=" .029"
          ixz=" .0137"
          iyy=" 1.1"
          iyz=" .0000537"
          izz=" 1.16"
        />
      </inertial>
    </link>

    <link name="${prefix}J1_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://robot_description/meshes/visual/j1.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://robot_description/meshes/collision/j1.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 62.8" />
        <origin xyz=" .0158 -.0106 -.0831" />
        <inertia
          ixx=" 1.35"
          ixy=" .133"
          ixz="-.0417"
          iyy=" 1.11"
          iyz="-.108"
          izz=" 1.3"
        />
      </inertial>
    </link>

    <link name="${prefix}J2_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://robot_description/meshes/visual/j2.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://robot_description/meshes/collision/j2.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 65.8" />
        <origin xyz="-.0343 -.172  .38" />
        <inertia
          ixx=" 4.86"
          ixy="-.0809"
          ixz=" .0453"
          iyy=" 4.98"
          iyz="-.118"
          izz=" .536"
        />
      </inertial>
    </link>

    <link name="${prefix}J3_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://robot_description/meshes/visual/j3.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://robot_description/meshes/collision/j3.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 52.9" />
        <origin xyz=" .134  .00796  .103" />
        <inertia
          ixx=" .901"
          ixy="-.0784"
          ixz="-.294"
          iyy=" 1.13"
          iyz="-.0385"
          izz=" 1.06"
        />
      </inertial>
    </link>

    <link name="${prefix}J4_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://robot_description/meshes/visual/j4.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://robot_description/meshes/collision/j4.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 20.2" />
        <origin xyz=" .586 -.0481 -.000358" />
        <inertia
          ixx=" .0769"
          ixy=" .053"
          ixz="-.00106"
          iyy=" .647"
          iyz="-.0000313"
          izz=" .656"
        />
      </inertial>
    </link>

    <link name="${prefix}J5_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://robot_description/meshes/visual/j5.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://robot_description/meshes/collision/j5.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 1.98" />
        <origin xyz=" .0276 -.0121  .000000522" />
        <inertia
          ixx=" .00394"
          ixy="-.000785"
          ixz=" .0000000339"
          iyy=" .00462"
          iyz=" .00000000332"
          izz=" .0041"
        />
      </inertial>
    </link>

    <link name="${prefix}J6_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://robot_description/meshes/visual/j6.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://robot_description/meshes/collision/j6.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" .558" />
        <origin xyz=" .0581 -.000000509  .000000147" />
        <inertia
          ixx=" .000585"
          ixy="-.00000000703"
          ixz=" .0000000019"
          iyy=" .000433"
          iyz=" .0000000227"
          izz=" .000433"
        />
      </inertial>
    </link>

    <!-- joints -->
    <joint name="${prefix}J1" type="revolute">
      <origin xyz=" 0  0  .425" rpy="0 0 0" />
      <parent link="${prefix}base_link" />
      <child link="${prefix}J1_link" />
      <axis xyz=" 0  0  1" />
      <limit
        lower="${j1_lower_limit}"
        upper="${j1_upper_limit}"
        effort="${j1_effort_limit}"
        velocity="${j1_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J2" type="revolute">
      <origin xyz=" .075  0  0" rpy="0 0 0" />
      <parent link="${prefix}J1_link" />
      <child link="${prefix}J2_link" />
      <axis xyz=" 0  1  0" />
      <limit
        lower="${j2_lower_limit}"
        upper="${j2_upper_limit}"
        effort="${j2_effort_limit}"
        velocity="${j2_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J3" type="revolute">
      <origin xyz=" 0  0  .84" rpy="0 0 0" />
      <parent link="${prefix}J2_link" />
      <child link="${prefix}J3_link" />
      <axis xyz=" 0 -1  0" />
      <limit
        lower="${j3_lower_limit}"
        upper="${j3_upper_limit}"
        effort="${j3_effort_limit}"
        velocity="${j3_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J4" type="revolute">
      <origin xyz=" 0  0  .215" rpy="0 0 0" />
      <parent link="${prefix}J3_link" />
      <child link="${prefix}J4_link" />
      <axis xyz="-1  0  0" />
      <limit
        lower="${j4_lower_limit}"
        upper="${j4_upper_limit}"
        effort="${j4_effort_limit}"
        velocity="${j4_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J5" type="revolute">
      <origin xyz=" .89  0  0" rpy="0 0 0" />
      <parent link="${prefix}J4_link" />
      <child link="${prefix}J5_link" />
      <axis xyz=" 0 -1  0" />
      <limit
        lower="${j5_lower_limit}"
        upper="${j5_upper_limit}"
        effort="${j5_effort_limit}"
        velocity="${j5_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J6" type="revolute">
      <origin xyz=" 0  0  0" rpy="0 0 0" />
      <parent link="${prefix}J5_link" />
      <child link="${prefix}J6_link" />
      <axis xyz="-1  0  0" />
      <limit
        lower="${j6_lower_limit}"
        upper="${j6_upper_limit}"
        effort="${j6_effort_limit}"
        velocity="${j6_velocity_limit}"
      />
    </joint>

    <!-- world coords -->
    <link name="${prefix}wbase" />
    <joint name="${prefix}base_link-wbase" type="fixed">
      <origin xyz=" 0  0  .425" rpy="0 0 0" />
      <parent link="${prefix}base_link" />
      <child link="${prefix}wbase" />
    </joint>

    <!-- flange coords -->
    <link name="${prefix}flange" />
    <joint name="${prefix}J6-flange" type="fixed">
      <origin xyz=" .09  0  0" rpy="0 0 0" />
      <parent link="${prefix}J6_link" />
      <child link="${prefix}flange" />
    </joint>

    <!-- FANUC flange coords -->
    <link name="${prefix}fanuc_flange" />
    <joint name="${prefix}flange-fanuc_flange" type="fixed">
      <origin xyz="0 0 0" rpy="${radians( 180)} ${radians(-90)} ${radians( 0)}" />
      <parent link="${prefix}flange" />
      <child link="${prefix}fanuc_flange" />
    </joint>

    <!-- Gocator 2450 collision model -->
    <link name="${prefix}gocator_sensor">
      <visual>
        <origin xyz="0 0 -0.270" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://robot_description/meshes/visual/Gocator_2450.dae" />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 -0.270" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://robot_description/meshes/collision/Gocator_2450.stl" scale="0.001 0.001 0.001" />
        </geometry>
      </collision>
    </link>
    <joint name="${prefix}fanuc_flange-gocator_sensor" type="fixed">
      <origin xyz="-0.011579 -0.004621 0.359284" rpy="0.485145 0.160648 -1.509479" />
      <parent link="${prefix}fanuc_flange" />
      <child link="${prefix}gocator_sensor" />
    </joint>

    <!-- Weld gun at TCP (nozzle tip) + visual mesh -->
    <link name="${prefix}weld_gun">
      <visual>
        <!-- 原始数模原点 = 焊枪枪嘴；weld_gun TF 原点同位置 -->
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://robot_description/meshes/visual/weldgun.stl" scale="0.001 0.001 0.001" />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://robot_description/meshes/visual/weldgun.stl" scale="0.001 0.001 0.001" />
        </geometry>
      </collision>
    </link>
    <joint name="${prefix}fanuc_flange-weld_gun" type="fixed">
      <!-- TCP_TO_FLANGE_POSE: 法兰→TCP -->
      <origin xyz="-0.046256 -0.000142 0.375235"
              rpy="-3.141540 -0.384130 -0.000070" />
      <parent link="${prefix}fanuc_flange" />
      <child link="${prefix}weld_gun" />
    </joint>

    <!-- tool0 = weld_gun 的别名（TCP参考坐标系） -->
    <link name="${prefix}tool0" />
    <joint name="${prefix}fanuc_flange-tool0" type="fixed">
      <origin xyz="-0.046256 -0.000142 0.375235"
              rpy="-3.141540 -0.384130 -0.000070" />
      <parent link="${prefix}fanuc_flange" />
      <child link="${prefix}tool0" />
    </joint>


    



<!-- Attach to parent -->
    <joint name="${prefix}base_joint" type="fixed">
      <xacro:insert_block name="origin" />
      <parent link="${parent}" />
      <child link="${prefix}base_link" />
    </joint>

    <!-- Attach child -->
    <joint name="${prefix}child_joint" type="fixed">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <parent link="${prefix}flange" />
      <child link="${child}" />
    </joint>
  </xacro:macro>
</robot>