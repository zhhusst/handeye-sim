<?xml version="1.0" ?>
<robot name="m20id25_calib">
  <link name="world" />
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="file:///workspace/meshes/base.dae" /></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="file:///workspace/meshes/base.dae" /></geometry>
    </collision>
    <inertial>
      <mass value="200.0"/>
      <inertia ixx="10.0" ixy="0.0" ixz="0.0" iyy="10.0" iyz="0.0" izz="10.0"/>
    </inertial>
  </link>
  <link name="J1_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="file:///workspace/meshes/j1.dae" /></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="file:///workspace/meshes/j1.dae" /></geometry>
    </collision>
    <inertial>
      <mass value="80.0"/>
      <inertia ixx="5.0" ixy="0.0" ixz="0.0" iyy="5.0" iyz="0.0" izz="5.0"/>
    </inertial>
  </link>
  <link name="J2_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="file:///workspace/meshes/j2.dae" /></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="file:///workspace/meshes/j2.dae" /></geometry>
    </collision>
    <inertial>
      <mass value="100.0"/>
      <inertia ixx="6.0" ixy="0.0" ixz="0.0" iyy="6.0" iyz="0.0" izz="6.0"/>
    </inertial>
  </link>
  <link name="J3_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="file:///workspace/meshes/j3.dae" /></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="file:///workspace/meshes/j3.dae" /></geometry>
    </collision>
    <inertial>
      <mass value="60.0"/>
      <inertia ixx="4.0" ixy="0.0" ixz="0.0" iyy="4.0" iyz="0.0" izz="4.0"/>
    </inertial>
  </link>
  <link name="J4_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="file:///workspace/meshes/j4.dae" /></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="file:///workspace/meshes/j4.dae" /></geometry>
    </collision>
    <inertial>
      <mass value="20.0"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
  </link>
  <link name="J5_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="file:///workspace/meshes/j5.dae" /></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="file:///workspace/meshes/j5.dae" /></geometry>
    </collision>
    <inertial>
      <mass value="15.0"/>
      <inertia ixx="0.5" ixy="0.0" ixz="0.0" iyy="0.5" iyz="0.0" izz="0.5"/>
    </inertial>
  </link>
  <link name="J6_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="file:///workspace/meshes/j6.dae" /></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="file:///workspace/meshes/j6.dae" /></geometry>
    </collision>
    <inertial>
      <mass value="8.0"/>
      <inertia ixx="0.3" ixy="0.0" ixz="0.0" iyy="0.3" iyz="0.0" izz="0.3"/>
    </inertial>
  </link>
  <link name="flange">
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>
  <link name="fanuc_flange" />
  <link name="ee_link" />
  <link name="gocator_sensor">
    <visual>
      <origin xyz="0 0 -0.270" rpy="0 0 0" />
      <geometry><mesh filename="file:///workspace/meshes/Gocator_2450.dae" /></geometry>
    </visual>
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>

  <!-- joints: unchanged from original -->
  <joint name="base_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="world" />
    <child link="base_link" />
  </joint>
  <joint name="J1_joint" type="revolute">
    <origin xyz="0 0 .425" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="J1_link" />
    <axis xyz="0 0 1" />
    <limit lower="-185" upper="185" effort="7000" velocity="210" />
  </joint>
  <joint name="J2_joint" type="revolute">
    <origin xyz=".075 0 0" rpy="0 0 0" />
    <parent link="J1_link" />
    <child link="J2_link" />
    <axis xyz="0 1 0" />
    <limit lower="-100" upper="160" effort="8000" velocity="210" />
  </joint>
  <joint name="J3_joint" type="revolute">
    <origin xyz="0 0 .84" rpy="0 0 0" />
    <parent link="J2_link" />
    <child link="J3_link" />
    <axis xyz="0 -1 0" />
    <limit lower="-90" upper="220" effort="4000" velocity="265" />
  </joint>
  <joint name="J4_joint" type="revolute">
    <origin xyz="0 0 .215" rpy="0 0 0" />
    <parent link="J3_link" />
    <child link="J4_link" />
    <axis xyz="-1 0 0" />
    <limit lower="-200" upper="200" effort="300" velocity="420" />
  </joint>
  <joint name="J5_joint" type="revolute">
    <origin xyz=".89 0 0" rpy="0 0 0" />
    <parent link="J4_link" />
    <child link="J5_link" />
    <axis xyz="0 -1 0" />
    <limit lower="-179.999" upper="179.999" effort="300" velocity="420" />
  </joint>
  <joint name="J6_joint" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="J5_link" />
    <child link="J6_link" />
    <axis xyz="-1 0 0" />
    <limit lower="-450" upper="450" effort="200" velocity="720" />
  </joint>
  <joint name="J6-flange_joint" type="fixed">
    <origin xyz=".09 0 0" rpy="0 0 0" />
    <parent link="J6_link" />
    <child link="flange" />
  </joint>
  <joint name="flange-fanuc_flange_joint" type="fixed">
    <origin xyz="0 0 0" rpy="3.14159 -1.5708 0" />
    <parent link="flange" />
    <child link="fanuc_flange" />
  </joint>
  <joint name="fanuc_flange-gocator_sensor_joint" type="fixed">
    <origin xyz="-0.011579 -0.004621 0.359284" rpy="0.485145 0.160648 -1.509479" />
    <parent link="fanuc_flange" />
    <child link="gocator_sensor" />
  </joint>
  <joint name="child_joint_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="flange" />
    <child link="ee_link" />
  </joint>

  <!-- ros2_control: Gazebo Sim ros2_control hardware interface -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="J1_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="J2_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="J3_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="J4_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="J5_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="J6_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- Gazebo Sim plugin loader for ros2_control -->
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>/workspace/ros2_ws/src/handeye_sim_bridge/config/gz_controllers.yaml</parameters>
    </plugin>
  </gazebo>
</robot>
